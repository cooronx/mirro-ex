[db]
url = "http://127.0.0.1:8123"
user = "rust_user"
password = "123456"
database = "default"
pool_size = 5

[db.tables]
sh_order = "SHOrder"
sz_order = "SZOrder"
transaction = "Transaction"

[db.schema]
market_schema_path = "scripts/create_local_clickhouse_tables.sql"
trading_db_path = "data/trading.db"
trading_schema_path = "scripts/create_trading_sqlite_schema.sql"

[replay]
# 每个channel提前拉取多少个批次
lane_queue_capacity = 8
# 主循环每隔多少毫秒推进一次 replay
tick_interval_ms = 5
# 输出盘口的档位深度
snapshot_depth = 5
# 是否导出 snapshot csv
write_snapshot_csv = true
# snapshot csv 输出路径
snapshot_csv_path = "data/order_book_snapshot.csv"
# 每次从数据库拉取多少条事件，越小越省内存，但查询次数会更多
batch_size = 100000

[nats]
url = "nats://127.0.0.1:4222"
subject = "market.snapshot"

[web]
host = "127.0.0.1"
port = 5800

[logging]
level = "info"
directory = "logs"
file_prefix = "mirro-ex"
to_stdout = true
to_file = true
